<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".BarberApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.BarberMovilApp"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"
            android:theme="@style/Theme.BarberMovilApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- [F10] Deep link para abrir la app desde notificaciones FCM.
                 Uso: Intent con URI barberapp://booking?id=123 desde BarberFirebaseMessagingService.
                 En NavGraph: navController.navigate("appointments") o pantalla de detalle. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="barberapp"
                    android:host="booking" />
            </intent-filter>
        </activity>

        <!-- [FIX] Canal por defecto para notificaciones FCM recibidas en background/killed.
             Sin esto, FCM usa 'fcm_fallback_notification_channel' (importancia baja)
             y las notificaciones pueden aparecer silenciosas en Android 8+. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="appointment_reminders" />

        <service
            android:name=".service.BarberFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- [FIX] Elimina WorkManagerInitializer del merge automático.
             BarberApp implementa Configuration.Provider (init manual con HiltWorkerFactory),
             por lo que el inicializador automático de androidx.startup debe removerse. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>
</manifest>
