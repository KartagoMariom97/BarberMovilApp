<?xml version="1.0" encoding="utf-8"?>
<!--
  [F12] Certificate pinning — protege contra ataques MITM interceptando la comunicación HTTPS.
  PASOS PARA OBTENER EL PIN DE PRODUCCIÓN:
    openssl s_client -connect <API_HOST>:443 </dev/null \
      | openssl x509 -pubkey -noout \
      | openssl pkey -pubin -outform der \
      | openssl dgst -sha256 -binary \
      | base64
  Reemplazar "REEMPLAZAR_CON_PIN_SHA256_DEL_SERVIDOR" con el resultado.
  Agregar un backup pin (siguiente certificado) para poder rotar sin romper la app.
-->
<network-security-config>

    <!-- Producción: solo HTTPS + certificate pinning -->
    <domain-config cleartextTrafficPermitted="false">
        <!-- TODO: reemplazar con el host real del API de producción -->
        <domain includeSubdomains="true">api.barberapp.com</domain>

        <pin-set expiration="2027-01-01">
            <!-- Pin primario — SHA-256 de la clave pública del certificado de producción -->
            <pin digest="SHA-256">REEMPLAZAR_CON_PIN_SHA256_DEL_SERVIDOR</pin>
            <!-- Pin de respaldo — para rotación de certificado sin forzar actualización de app -->
            <pin digest="SHA-256">REEMPLAZAR_CON_PIN_SHA256_DE_RESPALDO</pin>
        </pin-set>
    </domain-config>

    <!-- Desarrollo local: permite HTTP y sin pinning -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">192.168.0.0</domain>
    </domain-config>

</network-security-config>
