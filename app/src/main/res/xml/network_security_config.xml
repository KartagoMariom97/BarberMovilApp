<?xml version="1.0" encoding="utf-8"?>
<!--
  [F12] Certificate pinning — protege contra ataques MITM interceptando la comunicación HTTPS.
  PASOS PARA AGREGAR EL PIN CUANDO SE TENGA EL CERTIFICADO DE PRODUCCIÓN:
    openssl s_client -connect <API_HOST>:443 </dev/null \
      | openssl x509 -pubkey -noout \
      | openssl pkey -pubin -outform der \
      | openssl dgst -sha256 -binary \
      | base64
  Agregar el resultado en un bloque <pin-set> dentro del domain-config de producción.
  Incluir siempre un pin de respaldo para poder rotar certificado sin forzar actualización de app.
-->
<network-security-config>

    <!-- Producción: solo HTTPS; el pin-set se agrega cuando se tenga el certificado real -->
    <domain-config cleartextTrafficPermitted="false">
        <!-- TODO: reemplazar con el host real del API de producción -->
        <domain includeSubdomains="true">api.barberapp.com</domain>
    </domain-config>

    <!-- Desarrollo local: permite HTTP y sin pinning -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">192.168.0.0</domain>
    </domain-config>

</network-security-config>
